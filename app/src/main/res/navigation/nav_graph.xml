<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.sublingo.app.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action android:id="@+id/action_home_to_fileTranslate"
            app:destination="@id/fileTranslateFragment" />
        <action android:id="@+id/action_home_to_video"
            app:destination="@id/videoFragment" />
        <action android:id="@+id/action_home_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/fileTranslateFragment"
        android:name="com.sublingo.app.ui.translate.FileTranslateFragment"
        android:label="File Translate"
        tools:layout="@layout/fragment_file_translate">
        <action android:id="@+id/action_fileTranslate_to_progress"
            app:destination="@id/progressFragment" />
    </fragment>

    <fragment
        android:id="@+id/progressFragment"
        android:name="com.sublingo.app.ui.progress.ProgressFragment"
        android:label="Progress"
        tools:layout="@layout/fragment_progress">
        <argument android:name="fileUri" app:argType="string" />
        <argument android:name="fileName" app:argType="string" />
        <argument android:name="fileType" app:argType="string" />
        <argument android:name="sourceLang" app:argType="string" />
        <argument android:name="targetLang" app:argType="string" />
        <action android:id="@+id/action_progress_to_result"
            app:destination="@id/resultFragment"
            app:popUpTo="@id/fileTranslateFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/resultFragment"
        android:name="com.sublingo.app.ui.result.ResultFragment"
        android:label="Result"
        tools:layout="@layout/fragment_result">
        <argument android:name="outputPath" app:argType="string" />
        <argument android:name="lineCount" app:argType="integer" />
        <argument android:name="targetLang" app:argType="string" />
        <action android:id="@+id/action_result_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.sublingo.app.ui.history.HistoryFragment"
        android:label="History"
        tools:layout="@layout/fragment_history" />

    <fragment
        android:id="@+id/videoFragment"
        android:name="com.sublingo.app.ui.video.VideoFragment"
        android:label="Video"
        tools:layout="@layout/fragment_video" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.sublingo.app.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />
</navigation>
